{
  "project_language_settings": {
    "primary_language": "zh-CN",
    "secondary_languages": ["en-US"],
    "fallback_language": "en-US",
    "encoding": "utf-8"
  },
  "naming_conventions": {
    "directories": {
      "priority": "chinese_first",
      "format": "{chinese_name}-{english_abbreviation}",
      "examples": {
        "competitions": "竞赛项目",
        "projects": "项目开发",
        "research": "科研项目",
        "robotics": "机器人技术"
      }
    },
    "files": {
      "readme": {
        "primary": "README.md",
        "localized": ["README_zh.md", "README_en.md"],
        "content_language": "zh-CN"
      },
      "documentation": {
        "primary_language": "zh-CN",
        "include_english": true,
        "format": "markdown"
      },
      "code_comments": {
        "language": "zh-CN",
        "include_english_for_apis": true
      }
    }
  },
  "content_guidelines": {
    "documentation": {
      "structure": {
        "title": "中文标题 (English Title)",
        "description": "详细的中文描述，followed by English summary",
        "sections": [
          "项目概述 (Project Overview)",
          "技术架构 (Technical Architecture)",
          "安装指南 (Installation Guide)",
          "使用说明 (Usage Instructions)",
          "开发指南 (Development Guide)",
          "贡献指南 (Contributing Guide)"
        ]
      },
      "code_examples": {
        "comments_language": "zh-CN",
        "variable_naming": "english_with_chinese_comments"
      }
    },
    "commit_messages": {
      "format": "type(scope): 中文描述 [English description]",
      "examples": [
        "feat(机器人): 添加飞控通讯模块 [Add flight controller communication module]",
        "fix(竞赛): 修复电控组配置问题 [Fix electrical control group configuration]"
      ]
    }
  },
  "migration_rules": {
    "preserve_chinese_names": true,
    "add_english_alternatives": true,
    "update_existing_english_only": true,
    "maintain_compatibility": true
  },
  "quality_standards": {
    "documentation_completeness": {
      "chinese_content_required": true,
      "english_summary_recommended": true,
      "technical_terms_bilingual": true
    },
    "accessibility": {
      "encoding": "utf-8",
      "font_support": "chinese_fonts_priority",
      "internationalization_ready": true
    }
  },
  "tools_integration": {
    "git_hooks": {
      "pre_commit_language_check": true,
      "commit_message_format_check": true
    },
    "ide_settings": {
      "default_encoding": "utf-8",
      "spell_check_languages": ["zh-CN", "en-US"],
      "code_completion_language": "zh-CN"
    }
  }
}