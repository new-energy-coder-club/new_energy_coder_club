{
  "project_language_config": {
    "primary_language": "zh-CN",
    "secondary_languages": ["en-US"],
    "fallback_language": "en-US",
    "encoding": "UTF-8"
  },
  "directory_naming_rules": {
    "competitions": {
      "pattern": "{year}{competition_name_zh}-{category_zh}",
      "examples": [
        "2024华为云AI挑战赛",
        "2024电赛预选-EB25-SIG",
        "2025节能减排-DUMA组"
      ],
      "forbidden_patterns": [
        "chinese-project",
        "project-{number}",
        "competition-{id}"
      ]
    },
    "projects": {
      "robotics": {
        "pattern": "{project_type_zh}-{identifier}",
        "examples": [
          "人形机器人主线",
          "飞控通讯-250510",
          "电控组-RC5-RM1"
        ]
      },
      "research": {
        "pattern": "{research_area_zh}-{tech_identifier}",
        "examples": [
          "3D打印技术组",
          "灵巧手研究",
          "气动系统研究"
        ]
      },
      "ai": {
        "pattern": "{ai_domain_zh}-{application_zh}",
        "examples": [
          "能源监控系统",
          "智能识别平台"
        ]
      },
      "embedded": {
        "pattern": "{platform_zh}-{project_zh}",
        "examples": [
          "NearLink开发",
          "嵌入式控制系统"
        ]
      }
    }
  },
  "file_naming_rules": {
    "readme_files": {
      "primary": "README.md",
      "localized": {
        "zh-CN": "README_zh.md",
        "en-US": "README_en.md"
      },
      "content_priority": "zh-CN"
    },
    "documentation": {
      "pattern": "{document_name_zh}.md",
      "examples": [
        "项目说明.md",
        "技术文档.md",
        "使用指南.md"
      ]
    },
    "code_files": {
      "comments_language": "zh-CN",
      "variable_naming": "english_with_chinese_comments",
      "function_naming": "english_with_chinese_docs"
    }
  },
  "content_guidelines": {
    "readme_structure": {
      "title": "zh-CN primary, en-US secondary",
      "description": "zh-CN detailed, en-US summary",
      "installation": "zh-CN with en-US commands",
      "usage": "zh-CN examples with en-US code"
    },
    "documentation_priority": [
      "zh-CN (primary)",
      "en-US (secondary)",
      "code comments in zh-CN"
    ]
  },
  "migration_rules": {
    "directory_renaming": {
      "use_git_mv": true,
      "preserve_history": true,
      "update_references": true
    },
    "content_updates": {
      "update_internal_links": true,
      "update_documentation": true,
      "update_config_files": true
    },
    "validation": {
      "check_broken_links": true,
      "verify_git_history": true,
      "test_build_process": true
    }
  },
  "quality_standards": {
    "chinese_content": {
      "min_coverage": "80%",
      "required_sections": [
        "项目简介",
        "功能特性",
        "安装说明",
        "使用方法"
      ]
    },
    "english_content": {
      "min_coverage": "60%",
      "required_sections": [
        "Project Overview",
        "Key Features",
        "Installation",
        "Usage"
      ]
    }
  },
  "automation_tools": {
    "directory_validator": {
      "script": "tools/validate_chinese_naming.py",
      "check_frequency": "on_commit"
    },
    "content_checker": {
      "script": "tools/check_chinese_content.py",
      "check_frequency": "weekly"
    },
    "link_validator": {
      "script": "tools/validate_links.py",
      "check_frequency": "daily"
    }
  },
  "exceptions": {
    "keep_english": [
      "LICENSE",
      ".gitignore",
      "requirements.txt",
      "package.json",
      "Makefile"
    ],
    "technical_terms": [
      "API",
      "SDK",
      "IoT",
      "AI",
      "ML",
      "NearLink",
      "Robocon"
    ]
  }
}