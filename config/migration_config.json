  },
  "file_handling_rules": {
    "large_files": {
      "threshold_mb": 50,
      "action": "verify_git_lfs",
      "description": "检查大文件是否使用Git LFS"
    },
    "video_files": {
      "extensions": [".mp4", ".avi", ".mov", ".mkv"],
      "action": "compress_if_needed",
      "description": "视频文件处理"
    },
    "model_files": {
      "extensions": [".stl", ".obj", ".fbx", ".blend", ".step"],
      "action": "verify_git_lfs",
      "description": "3D模型文件处理"
    },
    "chinese_naming": {
      "action": "preserve_chinese",
      "description": "保持中文命名，优先使用中文",
      "fallback_english": true,
      "encoding": "utf-8"
    },
    "image_optimization": {
      "extensions": [".jpg", ".jpeg", ".png", ".bmp"],
      "action": "optimize_if_large",
      "threshold_kb": 1024,
      "description": "图片优化处理"
    }
  },
  "validation_rules": {
    "file_count_match": {
      "enabled": true,
      "tolerance": 0,
      "description": "验证文件数量匹配"
    },
    "size_match": {
      "enabled": true,
      "tolerance_kb": 1024,
      "description": "验证文件大小匹配（允许1KB差异）"
    },
    "structure_integrity": {
      "enabled": true,
      "check_readme": true,
      "check_main_files": true,
      "description": "验证目录结构完整性"
    }
  },
  "rollback_config": {
    "enabled": true,
    "keep_backups": 5,
    "backup_compression": false,
    "auto_cleanup_days": 30
  },
  "logging_config": {
    "level": "INFO",
    "format": "%(asctime)s - %(levelname)s - %(message)s",
    "file_rotation": true,
    "max_log_files": 10
  },
  "performance_config": {
    "parallel_processing": false,
    "max_workers": 4,
    "chunk_size_mb": 100,
    "progress_reporting": true
  },
  "git_config": {
    "preserve_history": true,
    "create_migration_branch": false,
    "commit_changes": false,
    "tag_migration": false
  }
}