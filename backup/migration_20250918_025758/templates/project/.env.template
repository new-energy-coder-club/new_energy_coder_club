# ===========================================
# {{PROJECT_NAME}} 环境配置文件
# ===========================================
# 请复制此文件为 .env 并填入实际配置值
# 注意：.env 文件包含敏感信息，不应提交到版本控制系统

# ===========================================
# 应用基础配置
# ===========================================

# 应用环境 (development/staging/production)
NODE_ENV={{NODE_ENV}}

# 应用名称
APP_NAME={{APP_NAME}}

# 应用版本
APP_VERSION={{APP_VERSION}}

# 应用端口
PORT={{PORT}}

# 应用主机地址
HOST={{HOST}}

# 应用基础URL
BASE_URL={{BASE_URL}}

# API基础URL
API_BASE_URL={{API_BASE_URL}}

# ===========================================
# 数据库配置
# ===========================================

# 数据库类型 (mysql/postgresql/mongodb/sqlite)
DB_TYPE={{DB_TYPE}}

# 数据库主机
DB_HOST={{DB_HOST}}

# 数据库端口
DB_PORT={{DB_PORT}}

# 数据库名称
DB_NAME={{DB_NAME}}

# 数据库用户名
DB_USER={{DB_USER}}

# 数据库密码
DB_PASSWORD={{DB_PASSWORD}}

# 数据库连接池配置
DB_POOL_MIN={{DB_POOL_MIN}}
DB_POOL_MAX={{DB_POOL_MAX}}

# 数据库SSL配置
DB_SSL={{DB_SSL}}

# ===========================================
# Redis配置
# ===========================================

# Redis主机
REDIS_HOST={{REDIS_HOST}}

# Redis端口
REDIS_PORT={{REDIS_PORT}}

# Redis密码
REDIS_PASSWORD={{REDIS_PASSWORD}}

# Redis数据库索引
REDIS_DB={{REDIS_DB}}

# Redis连接超时时间(毫秒)
REDIS_TIMEOUT={{REDIS_TIMEOUT}}

# ===========================================
# 认证和安全配置
# ===========================================

# JWT密钥
JWT_SECRET={{JWT_SECRET}}

# JWT过期时间
JWT_EXPIRES_IN={{JWT_EXPIRES_IN}}

# JWT刷新令牌过期时间
JWT_REFRESH_EXPIRES_IN={{JWT_REFRESH_EXPIRES_IN}}

# 密码加密盐值轮数
BCRYPT_ROUNDS={{BCRYPT_ROUNDS}}

# 会话密钥
SESSION_SECRET={{SESSION_SECRET}}

# CORS允许的源
CORS_ORIGIN={{CORS_ORIGIN}}

# ===========================================
# 第三方服务配置
# ===========================================

# 邮件服务配置
MAIL_HOST={{MAIL_HOST}}
MAIL_PORT={{MAIL_PORT}}
MAIL_USER={{MAIL_USER}}
MAIL_PASSWORD={{MAIL_PASSWORD}}
MAIL_FROM={{MAIL_FROM}}

# 短信服务配置
SMS_PROVIDER={{SMS_PROVIDER}}
SMS_API_KEY={{SMS_API_KEY}}
SMS_API_SECRET={{SMS_API_SECRET}}

# 对象存储配置
OSS_PROVIDER={{OSS_PROVIDER}}
OSS_ACCESS_KEY={{OSS_ACCESS_KEY}}
OSS_SECRET_KEY={{OSS_SECRET_KEY}}
OSS_BUCKET={{OSS_BUCKET}}
OSS_REGION={{OSS_REGION}}
OSS_ENDPOINT={{OSS_ENDPOINT}}

# CDN配置
CDN_URL={{CDN_URL}}
CDN_API_KEY={{CDN_API_KEY}}

# ===========================================
# 支付服务配置
# ===========================================

# 支付宝配置
ALIPAY_APP_ID={{ALIPAY_APP_ID}}
ALIPAY_PRIVATE_KEY={{ALIPAY_PRIVATE_KEY}}
ALIPAY_PUBLIC_KEY={{ALIPAY_PUBLIC_KEY}}

# 微信支付配置
WECHAT_APP_ID={{WECHAT_APP_ID}}
WECHAT_MCH_ID={{WECHAT_MCH_ID}}
WECHAT_API_KEY={{WECHAT_API_KEY}}

# ===========================================
# 社交登录配置
# ===========================================

# GitHub OAuth
GITHUB_CLIENT_ID={{GITHUB_CLIENT_ID}}
GITHUB_CLIENT_SECRET={{GITHUB_CLIENT_SECRET}}

# Google OAuth
GOOGLE_CLIENT_ID={{GOOGLE_CLIENT_ID}}
GOOGLE_CLIENT_SECRET={{GOOGLE_CLIENT_SECRET}}

# 微信登录
WECHAT_LOGIN_APP_ID={{WECHAT_LOGIN_APP_ID}}
WECHAT_LOGIN_APP_SECRET={{WECHAT_LOGIN_APP_SECRET}}

# ===========================================
# 监控和日志配置
# ===========================================

# 日志级别 (error/warn/info/debug)
LOG_LEVEL={{LOG_LEVEL}}

# 日志文件路径
LOG_FILE={{LOG_FILE}}

# 日志最大文件大小
LOG_MAX_SIZE={{LOG_MAX_SIZE}}

# 日志文件保留天数
LOG_MAX_DAYS={{LOG_MAX_DAYS}}

# Sentry DSN (错误监控)
SENTRY_DSN={{SENTRY_DSN}}

# 性能监控配置
APM_SERVER_URL={{APM_SERVER_URL}}
APM_SECRET_TOKEN={{APM_SECRET_TOKEN}}

# ===========================================
# 缓存配置
# ===========================================

# 缓存类型 (memory/redis/memcached)
CACHE_TYPE={{CACHE_TYPE}}

# 缓存默认过期时间(秒)
CACHE_TTL={{CACHE_TTL}}

# 缓存键前缀
CACHE_PREFIX={{CACHE_PREFIX}}

# ===========================================
# 队列配置
# ===========================================

# 队列类型 (redis/rabbitmq/sqs)
QUEUE_TYPE={{QUEUE_TYPE}}

# 队列连接URL
QUEUE_URL={{QUEUE_URL}}

# 默认队列名称
DEFAULT_QUEUE={{DEFAULT_QUEUE}}

# ===========================================
# 搜索引擎配置
# ===========================================

# Elasticsearch配置
ELASTICSEARCH_URL={{ELASTICSEARCH_URL}}
ELASTICSEARCH_INDEX={{ELASTICSEARCH_INDEX}}

# ===========================================
# 开发和调试配置
# ===========================================

# 是否启用调试模式
DEBUG={{DEBUG}}

# 是否启用热重载
HOT_RELOAD={{HOT_RELOAD}}

# 是否启用源码映射
SOURCE_MAP={{SOURCE_MAP}}

# 是否启用性能分析
PROFILING={{PROFILING}}

# API文档是否启用
API_DOCS_ENABLED={{API_DOCS_ENABLED}}

# ===========================================
# 特性开关配置
# ===========================================

# 是否启用用户注册
ENABLE_REGISTRATION={{ENABLE_REGISTRATION}}

# 是否启用邮箱验证
ENABLE_EMAIL_VERIFICATION={{ENABLE_EMAIL_VERIFICATION}}

# 是否启用短信验证
ENABLE_SMS_VERIFICATION={{ENABLE_SMS_VERIFICATION}}

# 是否启用双因子认证
ENABLE_2FA={{ENABLE_2FA}}

# 是否启用API限流
ENABLE_RATE_LIMITING={{ENABLE_RATE_LIMITING}}

# ===========================================
# 业务配置
# ===========================================

# 文件上传最大大小(MB)
MAX_FILE_SIZE={{MAX_FILE_SIZE}}

# 允许的文件类型
ALLOWED_FILE_TYPES={{ALLOWED_FILE_TYPES}}

# 分页默认大小
DEFAULT_PAGE_SIZE={{DEFAULT_PAGE_SIZE}}

# 分页最大大小
MAX_PAGE_SIZE={{MAX_PAGE_SIZE}}

# ===========================================
# 自定义配置
# ===========================================

# 项目特定的配置项
{{CUSTOM_CONFIG_1}}={{CUSTOM_VALUE_1}}
{{CUSTOM_CONFIG_2}}={{CUSTOM_VALUE_2}}
{{CUSTOM_CONFIG_3}}={{CUSTOM_VALUE_3}}

# ===========================================
# 注意事项
# ===========================================
# 1. 请勿在此文件中使用中文或特殊字符作为变量名
# 2. 布尔值请使用 true/false
# 3. 数字值请不要加引号
# 4. 字符串值如包含特殊字符请用引号包围
# 5. 敏感信息请使用强密码和复杂密钥
# 6. 生产环境请使用不同的配置值
# 7. 定期更新密钥和证书